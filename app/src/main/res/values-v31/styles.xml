<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ 主题：额外配置系统 splash 背景和启动图标。 -->
    <style name="AppTheme" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowBackground">@drawable/app_launch_background</item>
        <item name="android:windowSplashScreenBackground">#050B0A</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_launcher_histogram</item>
        <item name="android:colorAccent">#65F7BD</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">#050B0A</item>
        <item name="android:navigationBarColor">#050B0A</item>
    </style>
</resources>
